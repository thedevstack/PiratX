<?xml version="1.0" encoding="utf-8"?>
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="NewApi">

    <font
        android:font="@font/noto_sans_regular"
        android:fontStyle="normal"
        android:fontWeight="400"
        app:font="@font/noto_sans_regular"
        app:fontStyle="normal"
        app:fontWeight="400"
        tools:ignore="NewApi" />
    <font
        android:font="@font/noto_sans_italic"
        android:fontStyle="italic"
        android:fontWeight="400"
        app:font="@font/noto_sans_italic"
        app:fontStyle="italic"
        app:fontWeight="400"
        tools:ignore="NewApi" />
    <font
        android:font="@font/noto_sans_medium"
        android:fontStyle="normal"
        android:fontWeight="500"
        app:font="@font/noto_sans_medium"
        app:fontStyle="normal"
        app:fontWeight="500"
        tools:ignore="NewApi" />
    <font
        android:font="@font/noto_sans_medium_italic"
        android:fontStyle="italic"
        android:fontWeight="500"
        app:font="@font/noto_sans_medium_italic"
        app:fontStyle="italic"
        app:fontWeight="500"
        tools:ignore="NewApi" />
    <font
        android:font="@font/noto_sans_bold"
        android:fontStyle="normal"
        android:fontWeight="700"
        app:font="@font/noto_sans_bold"
        app:fontStyle="normal"
        app:fontWeight="700"
        tools:ignore="NewApi" />
    <font
        android:font="@font/noto_sans_bold_italic"
        android:fontStyle="italic"
        android:fontWeight="700"
        app:font="@font/noto_sans_bold_italic"
        app:fontStyle="italic"
        app:fontWeight="700"
        tools:ignore="NewApi" />

</font-family>
